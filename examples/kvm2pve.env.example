# kvm2pve QMP migration config
# Copy this file to kvm2pve.env on both source and destination hosts.

VM_NAME=kvm3023
SRC_DISK=/dev/centos/kvm3023_img

# Auto-filled by ./kvm2pve-src.sh discover
QEMU_DEVICE=
QEMU_NODE=

BITMAP=kvm2pve
TARGET_NODE=kvm2pve-target

PVE_HOST=CHANGE_ME
PVE_SSH_USER=root
PVE_SSH_PORT=22
PVE_VMID=2672
PVE_DISK=/dev/pve/vm-2672-disk-0

NBD_PORT=10809
NBD_EXPORT=kvm3023
TUNNEL_MODE=autossh
AUTOSSH_MONITOR_PORT=20000

AUTO_DISMISS_RUNNING_JOBS=true
